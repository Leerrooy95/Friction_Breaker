# Friction Breaker — API Keys
# Copy this file to .env and fill in your key.

# Required: Anthropic Claude (for mechanism classification + countermeasure analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override the default Claude model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Customize the rate limit for /analyze (default: 10 per minute)
# Uses flask-limiter syntax, e.g. "20 per minute", "100 per hour"
# RATE_LIMIT=10 per minute
